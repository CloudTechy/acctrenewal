# ===================================
# Supabase Configuration
# ===================================
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key_here
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# ===================================
# Paystack Payment Gateway (Staging / Test)
# ===================================
NEXT_PUBLIC_PAYSTACK_PUBLIC_KEY=pk_test_your_public_key_here
PAYSTACK_SECRET_KEY=sk_test_your_secret_key_here
PAYSTACK_WEBHOOK_SECRET=your_test_webhook_secret_here

# ===================================
# RADIUS Manager API
# ===================================
RADIUS_API_URL=http://165.227.177.208/radiusmanager/api/sysapi.php
RADIUS_API_USER=apiconnekt
RADIUS_API_PASS=C0nNekt123

# ===================================
# MikroTik Router Configuration - Awka
# ===================================
